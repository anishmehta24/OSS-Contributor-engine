# Template for environment variables.
# Copy this file to `.env` (which is gitignored) and fill in real values there.
# NEVER paste real keys into this file — it gets committed to git.

# --- GitHub ---
# Fine-grained PAT with "Public Repositories (read-only)" preset.
# Create at: https://github.com/settings/personal-access-tokens
GITHUB_TOKEN=github_pat_REPLACE_ME

# --- LLM providers (LiteLLM router uses primary, falls back to others) ---
# Gemini free tier:  https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Groq free tier:    https://console.groq.com/keys
GROQ_API_KEY=

# --- Embeddings ---
# Voyage AI free tier: https://www.voyageai.com
VOYAGE_API_KEY=

# --- App config ---
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./oss_engine.db

# --- Safety rails (v3 — Batch 37) ---
# Per-user lifetime LLM spend ceiling in USD. The pilot refuses to start
# once a user crosses this. Set to 0 for no cap.
# MAX_USER_COST_USD=5.0
# Comma-separated owners or owner/repo slugs the pilot will NOT fork, push
# to, or PR against (maintainers who opted out of AI-generated PRs).
# Case-insensitive. "owner" blocks all their repos; "owner/repo" blocks one.
# PILOT_REFUSE_LIST=some-org,another-org/specific-repo

# --- Sandbox (v3 — Autonomous Contribution Pilot) ---
# Docker image tag the per-investigation sandbox uses. Built once via:
#   uv run python -m app.sandbox build
# Override only if you've rebuilt with a different tag.
# SANDBOX_IMAGE=oss-engine-sandbox:latest
# SANDBOX_WORKSPACE_ROOT=.sandbox
# SANDBOX_MEMORY_LIMIT=1g
# SANDBOX_CPUS=1.0
# SANDBOX_DEFAULT_TIMEOUT_S=300

# --- OAuth post-login redirect ---
# Where FastAPI sends the browser after a successful GitHub OAuth callback.
# The session token is appended as ?session=<signed-value>; the Next.js
# /auth/handoff route handler reads it and re-sets it as an httpOnly cookie
# on the frontend's origin.
#
# Default points at the local Next.js dev server. Override in prod to your
# deployed frontend URL.
# OAUTH_POST_LOGIN_REDIRECT=http://localhost:3000/auth/handoff
