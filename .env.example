# Template for environment variables.
# Copy this file to `.env` (which is gitignored) and fill in real values there.
# NEVER paste real keys into this file — it gets committed to git.
#
# Sections marked [LOCAL] are for local dev; [DEPLOY] are what Render /
# Vercel need. Most overlap.

# ===========================================================================
# Database
# ===========================================================================
# [LOCAL]  SQLite file — zero setup, the default.
# [DEPLOY] Postgres connection string from Neon (https://neon.tech).
#          Render-style "postgres://" URLs are auto-rewritten on load.
#          Run once on the Neon SQL console:  CREATE EXTENSION vector;
DATABASE_URL=sqlite:///./oss_engine.db
# DATABASE_URL=postgresql+psycopg://USER:PASS@HOST/DB?sslmode=require

# ===========================================================================
# Embeddings
# ===========================================================================
# [LOCAL]  "local" = sentence-transformers (384-dim, free, needs the
#          local-embeddings extra: `uv sync --extra local-embeddings`).
# [DEPLOY] "voyage" = Voyage AI hosted (1024-dim). Required on free PaaS:
#          torch/sentence-transformers won't fit in 512 MB RAM.
EMBEDDER_BACKEND=local
# EMBEDDER_BACKEND=voyage
VOYAGE_API_KEY=                            # only needed when backend=voyage

# ===========================================================================
# LLM providers (LiteLLM router fallback: Gemini → Groq 70b → Groq 8b)
# ===========================================================================
# Gemini free tier: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Groq free tier:   https://console.groq.com/keys
GROQ_API_KEY=

# ===========================================================================
# GitHub OAuth + session crypto
# ===========================================================================
# Register an OAuth App at https://github.com/settings/developers
#   Homepage URL: your frontend URL (http://localhost:3001 locally, your
#                 vercel.app URL deployed)
#   Authorization callback URL: must EXACTLY match OAUTH_REDIRECT_URI below
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# SESSION_SECRET MUST be a valid Fernet key (44-char url-safe base64).
# It's reused as the AES key that encrypts OAuth tokens at rest, so a weak
# value breaks both session signing AND token decryption.
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SESSION_SECRET=
SESSION_MAX_AGE_S=604800                   # 7 days

# OAuth callback URL — backend route GitHub redirects to.
# [LOCAL]  http://localhost:8000/auth/callback
# [DEPLOY] https://<your-api>.onrender.com/auth/callback
OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback

# Post-login redirect — where the backend sends the browser after the
# OAuth handshake completes. Session token is appended as ?session=<...>;
# the Next.js /auth/handoff route reads it and sets a first-party cookie.
# [LOCAL]  http://localhost:3001/auth/handoff
# [DEPLOY] https://<your-app>.vercel.app/auth/handoff
OAUTH_POST_LOGIN_REDIRECT=http://localhost:3001/auth/handoff

# ===========================================================================
# Optional — server-side GitHub PAT
# ===========================================================================
# Used for unauthenticated repo reads (e.g. landing page stats). The OAuth
# flow above grants per-user tokens for everything else.
# Fine-grained PAT, "Public Repositories (read-only)" preset:
#   https://github.com/settings/personal-access-tokens
GITHUB_TOKEN=

# ===========================================================================
# App / logging
# ===========================================================================
LOG_LEVEL=INFO

# ===========================================================================
# Deploy flag — Autonomous Pilot
# ===========================================================================
# The Pilot opens a Docker sandbox + git-clones repos. Free PaaS (Render,
# Vercel, Fly free) gives you neither a Docker daemon nor persistent disk,
# so the hosted deploy sets this false and shows a "run locally" card
# instead of the launcher.
# [LOCAL]  true (default)
# [DEPLOY] false
PILOT_ENABLED=true

# ===========================================================================
# Safety rails (Batch 37) — only used when PILOT_ENABLED=true
# ===========================================================================
# Per-user lifetime LLM spend ceiling in USD. The pilot refuses to start
# once a user crosses this. 0 = no cap.
# MAX_USER_COST_USD=5.0
# Comma-separated owners or owner/repo slugs the pilot will NOT touch
# (maintainers who opted out of AI-generated PRs). Case-insensitive.
# PILOT_REFUSE_LIST=some-org,another-org/specific-repo

# ===========================================================================
# Sandbox (only used when PILOT_ENABLED=true)
# ===========================================================================
# Built once via:  uv run python -m app.sandbox build
# SANDBOX_IMAGE=oss-engine-sandbox:latest
# SANDBOX_WORKSPACE_ROOT=.sandbox
# SANDBOX_MEMORY_LIMIT=1g
# SANDBOX_CPUS=1.0
# SANDBOX_DEFAULT_TIMEOUT_S=300

# ===========================================================================
# Frontend (Vercel) — set these in the Vercel dashboard, NOT here
# ===========================================================================
# FASTAPI_URL=https://<your-api>.onrender.com
#   Used by next.config rewrites: the browser hits /api/* which Next
#   proxies to FASTAPI_URL server-side. Keeps cookies first-party.
